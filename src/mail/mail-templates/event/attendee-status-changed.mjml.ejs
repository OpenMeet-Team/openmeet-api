<%- include('./../layouts/header.mjml.ejs') %>

      <!-- Main Content -->
      <mj-section>
        <mj-column>

          <mj-text>
            Hello,
          </mj-text>

          <mj-text>
            Your status for the event <strong>
              <a href="<%= tenantConfig?.frontendDomain + '/events/' + eventAttendee?.event?.slug %>"><%= eventAttendee?.event?.name %></a>
            </strong>, has been updated to <strong>
              <%= eventAttendee?.status %>
            </strong>.
          </mj-text>

          <mj-text>
            Your role is <strong>
              <%= eventAttendee?.role?.name %>
            </strong>.
          </mj-text>

        </mj-column>
      </mj-section>

      <!-- Button -->
      <mj-section padding="20px">
        <mj-column>
          <mj-button href="<%= tenantConfig?.frontendDomain + '/events/' + eventAttendee?.event?.slug %>" background-color="#7B71DA" color="#FFFFFF" font-size="16px">
            View Event
          </mj-button>
        </mj-column>
      </mj-section>

      <!-- Footer Info -->
      <mj-section padding="10px">
        <mj-column>
          <mj-text font-size="12px" color="#666666">
            You received this email because you joined this event.
          </mj-text>
          <mj-text font-size="12px" color="#666666" padding-top="10px">
            To change your email settings, visit your
            <a href="<%= tenantConfig?.frontendDomain %>/dashboard/profile" style="color: #7B71DA;">profile settings</a>.
          </mj-text>
        </mj-column>
      </mj-section>

<%- include('./../layouts/footer.mjml.ejs') %>