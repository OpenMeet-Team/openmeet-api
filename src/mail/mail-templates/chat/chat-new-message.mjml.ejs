<%- include('./../layouts/header.mjml.ejs') %>

      <!-- Main Content -->
      <mj-section>
        <mj-column>

          <mj-text>
            Hello,
          </mj-text>

          <mj-text>
            <strong><%= participant?.firstName %> <%= participant?.lastName %></strong> sent you a new message.
          </mj-text>

        </mj-column>
      </mj-section>

      <!-- Button -->
      <mj-section padding="20px">
        <mj-column>
          <mj-button href="<%= tenantConfig?.frontendDomain %>/dashboard/chat" background-color="#7B71DA" color="#FFFFFF" font-size="16px">
            View Chat
          </mj-button>
        </mj-column>
      </mj-section>

      <!-- Footer Info -->
      <mj-section padding="10px">
        <mj-column>
          <mj-text font-size="12px" color="#666666">
            You received this email because you're in this conversation.
          </mj-text>
          <mj-text font-size="12px" color="#666666" padding-top="10px">
            To change your email settings, visit your
            <a href="<%= tenantConfig?.frontendDomain %>/dashboard/profile" style="color: #7B71DA;">profile settings</a>.
          </mj-text>
        </mj-column>
      </mj-section>

<%- include('./../layouts/footer.mjml.ejs') %>
